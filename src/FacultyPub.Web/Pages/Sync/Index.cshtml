@page
@model FacultyPub.Web.Pages.Sync.IndexModel
@{
    ViewData["Title"] = "Sync";
}
<h1>OpenAlex Sync</h1>
@if (TempData["Message"] is string message)
{
    <div class="alert alert-info">@message</div>
}
@if (!Model.IsOpenAlexConfigured)
{
    <div class="alert alert-warning">OpenAlex API key is not configured. Sync is disabled until <code>OpenAlex:ApiKey</code> is set.</div>
}
<form method="post" asp-page-handler="Run" class="mb-4">
    <button class="btn btn-primary" @(Model.IsOpenAlexConfigured ? null : "disabled")>Run Manual Sync for Verified Authors</button>
</form>
<h2>Recent Sync Runs</h2>
<table class="table table-striped table-sm">
    <thead><tr><th>ID</th><th>Type</th><th>Status</th><th>Started</th><th>Finished</th><th>Authors</th><th>Inserted</th><th>Updated</th><th>Unchanged</th><th>Errors</th><th>Message</th></tr></thead>
    <tbody>
    @foreach (var run in Model.Runs)
    {
        <tr>
            <td>@run.SyncRunId</td>
            <td>@run.SyncType</td>
            <td>@run.Status</td>
            <td>@run.StartedUtc</td>
            <td>@run.FinishedUtc</td>
            <td>@run.AuthorsChecked</td>
            <td>@run.WorksInserted</td>
            <td>@run.WorksUpdated</td>
            <td>@run.WorksUnchanged</td>
            <td>@run.ErrorsCount</td>
            <td>@run.Message</td>
        </tr>
    }
    </tbody>
</table>
