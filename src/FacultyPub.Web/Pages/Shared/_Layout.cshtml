<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Faculty Publications</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" asp-page="/Index">FacultyPub</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarsExampleDefault">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarsExampleDefault">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" asp-page="/Faculty/Index">Faculty</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Matches/Index">Matches</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Publications/Index">Publications</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Publications/ByDepartment">By Department</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Lookup/Index">Lookup</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Sync/Index">Sync</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Errors/Index">Errors</a></li>
            </ul>
        </div>
    </div>
</nav>
<main class="container my-4">
    @RenderBody()
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
